POSTGRES_DB=carcare
POSTGRES_USER=carcare
POSTGRES_PASSWORD=carcare
POSTGRES_PORT=5432
API_PORT=18081
WEB_PORT=19006
EXPO_PUBLIC_API_BASE_URL=http://localhost:18081

# Demo default: always re-apply schema.sql and data.sql on API startup.
# Change to never when you want PostgreSQL data to persist across API restarts.
SQL_INIT_MODE=always
